# === OpenAI (required — used for Pedro tutor, answer eval, concept picking) ===
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# === Google Gemini 3.1 Pro (required — used for Manim visualization generation) ===
GEMINI_API_KEY=your-gemini-api-key-here

# === Anthropic (optional — alternative for notebook generation) ===
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Kimi K2.5 via NVIDIA NIM (optional — alternative for Pedro tutor) ===
# KIMI_API_KEY=nvapi-your-key-here

# === Auth (required for production login) ===
JWT_SECRET=generate-a-long-random-string-here

# Google Sign-In — create OAuth 2.0 Web client at https://console.cloud.google.com/
# Authorized JavaScript origins: http://localhost:5173, https://your-vercel-app.vercel.app
# Authorized redirect URIs: same origins (GIS uses popup, no redirect needed for basic flow)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Email verification (Resend) — https://resend.com
RESEND_API_KEY=re_your_resend_key
RESEND_FROM=Coast <onboarding@yourdomain.com>

# Dev only: return verification codes in API response (never enable in production)
# AUTH_DEV_EXPOSE_CODES=true
